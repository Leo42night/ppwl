{
  "name": "backend",
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "db:generate": "bun prisma generate",
    "db:push": "bun --env-file=.env.local x --bun prisma db push",
    "db:reset": "bun --env-file=.env.local x --bun prisma migrate reset --force",
    "db:sql": "bunx prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script > baseline.sql",
    "db:seed": "bun --env-file=.env.prod prisma/seed.ts",
    "db:dev-seed": "bun prisma/seed.ts",
    "build": "prisma generate && tsdown src/index.ts",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "prisma": "^7.5.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}